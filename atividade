def registrar_venda(id_cliente, id_produto, quantidade):
    cursor.execute("SELECT preco, estoque FROM Produto WHERE id_produto = ?", (id_produto,))
    preco, estoque = cursor.fetchone()

    if estoque >= quantidade:
        total = preco * quantidade

        cursor.execute("INSERT INTO Venda (id_cliente, total, data_venda) VALUES (?, ?, date('now'))",
                       (id_cliente, total))

        cursor.execute("UPDATE Produto SET estoque = ? WHERE id_produto = ?",
                       (estoque - quantidade, id_produto))

        print("Venda realizada!")
    else:
        print("Estoque insuficiente!")

registrar_venda(1, 1, 2)


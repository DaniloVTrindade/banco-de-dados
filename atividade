def registrar_venda(id_cliente, id_produto, quantidade):
    # Buscar produto
    cursor.execute("SELECT preco, estoque FROM Produto WHERE id_produto = ?", (id_produto,))
    produto = cursor.fetchone()

    preco, estoque = produto

    if estoque >= quantidade:
        total = preco * quantidade

        # Registrar venda
        cursor.execute("""
        INSERT INTO Venda (id_cliente, total, data_venda)
        VALUES (?, ?, date('now'))
        """, (id_cliente, total))

        # Atualizar estoque
        novo_estoque = estoque - quantidade
        cursor.execute("""
        UPDATE Produto SET estoque = ?
        WHERE id_produto = ?
        """, (novo_estoque, id_produto))

        print("Venda realizada com sucesso!")
    else:
        print("Estoque insuficiente!")

